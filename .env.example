# Global Pulse — Required environment variables
# Copy to .env.local and fill in values.
# For Vercel: Project Settings → Environment Variables

# Auth (required for login)
AUTH_PASSWORD=your-shared-password
SESSION_SECRET=your-session-secret-min-32-chars

# Database (pooled connection preferred)
DATABASE_URL_POOLED=postgresql://...
# Or: DATABASE_URL, POSTGRES_URL, SUPABASE_DB_URL

# Agent & APIs
ANTHROPIC_API_KEY=sk-ant-...
WEATHER_API_KEY=
NEWS_API_KEY=
RESEND_API_KEY=

# Cron (for scheduled emails)
CRON_SECRET=
